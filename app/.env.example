# This file is kept for backwards compatibility — the canonical example now
# lives at the repo root: ../.env.example
#
# config.py calls dotenv.load_dotenv() with no args, which finds `.env` either
# in the CWD or by walking up the tree. Running the server with
#   `PYTHONPATH=app .venv/bin/python -u app/server.py`
# from the repo root means `.env` at the repo root is picked up automatically.
#
# If you'd prefer to keep your secrets next to the Python code, copy
# `../.env.example` to `app/.env` instead.
